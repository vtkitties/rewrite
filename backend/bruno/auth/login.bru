meta {
  name: login
  type: http
  seq: 3
}

post {
  url: {{host}}/api/auth/login
  body: json
  auth: inherit
}

body:json {
  {
    "email": "me@asdf.com",
    "password": "pass"
  }
}

script:post-response {
  let data = res.getBody();
  bru.setEnvVar("token",data.token);
}

settings {
  encodeUrl: true
  timeout: 0
}
